# ═══════════════════════════════════════════════════════════════════════════
# n8neiritech — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────
# PostgreSQL
# ─────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=n8neiritech
POSTGRES_USER=n8neiritech
POSTGRES_PASSWORD=n8neiritech_secret

# ─────────────────────────────
# Redis
# ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─────────────────────────────
# JWT
# ─────────────────────────────
# Gere uma chave segura: openssl rand -base64 48
JWT_SECRET=change-this-jwt-secret-key-minimum-32-characters-here
JWT_ISSUER=n8neiritech
JWT_AUDIENCE=n8neiritech-clients
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ─────────────────────────────
# n8n
# ─────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
# Gere uma chave: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-this-n8n-encryption-key-minimum-32-chars
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123

# ─────────────────────────────
# WhatsApp
# ─────────────────────────────
# Opções: Fake (dev), EvolutionApi, WppConnect, ZApi
WHATSAPP_PROVIDER=Fake
WHATSAPP_BASE_URL=http://localhost:8080
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE=default
WHATSAPP_WEBHOOK_SECRET=change-this-webhook-secret-here

# ─────────────────────────────
# Inteligência Artificial
# ─────────────────────────────
# Opções: None (sem IA), OpenAI, Anthropic, Google, Azure
AI_PROVIDER=None
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1000
AI_TIMEOUT_SECONDS=30

# ─────────────────────────────
# Google Sheets (opcional)
# ─────────────────────────────
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_REFRESH_TOKEN=

# ─────────────────────────────
# URLs e CORS
# ─────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────
# Chave API Interna (n8n → Backend)
# ─────────────────────────────
# Gere uma chave: openssl rand -hex 32
N8N_INTERNAL_API_KEY=change-this-internal-api-key-here

# ─────────────────────────────
# Portas dos serviços
# ─────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ─────────────────────────────
# Configurações do sistema
# ─────────────────────────────
SEED_DATA=true
APPLY_MIGRATIONS_ON_STARTUP=true
