# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=n8neiritech
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Connection String (será montada automaticamente)
CONNECTION_STRING=Host=postgres;Port=5432;Database=n8neiritech;Username=postgres;Password=postgres123

# Redis Configuration
REDIS_CONNECTION_STRING=redis:6379

# JWT Configuration
JWT_SECRET=change-this-secret-key-in-production-minimum-32-characters-long-for-security
JWT_ISSUER=n8neiritech
JWT_AUDIENCE=n8neiritech-clients
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# WhatsApp Configuration
WHATSAPP_PROVIDER=Fake
WHATSAPP_BASE_URL=http://localhost:8080
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_NAME=default
WHATSAPP_WEBHOOK_SECRET=change-this-webhook-secret-in-production

# AI Configuration
# Providers: None, OpenAI, Google
# Google Models (free): gemini-1.5-flash (recomendado), gemini-1.5-pro, gemini-pro
AI_PROVIDER=Google
AI_BASE_URL=https://generativelanguage.googleapis.com
AI_API_KEY=your-google-api-key-here
AI_MODEL=gemini-1.5-flash

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Internal API Key
INTERNAL_API_KEY=change-this-internal-api-key-in-production

# Application Configuration
SEED_DATA=true
APPLY_MIGRATIONS_ON_STARTUP=true
ASPNETCORE_ENVIRONMENT=Development
