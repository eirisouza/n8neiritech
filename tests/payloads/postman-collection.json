{
  "info": {
    "name": "n8neiritech API",
    "description": "Coleção de testes para a API n8neiritech",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', r.accessToken);",
                  "pm.collectionVariables.set('refreshToken', r.refreshToken);",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@demo.com\",\"password\":\"Admin@123456\"}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "****** {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&pageSize=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products?q=arroz&inStock=true",
              "query": [
                { "key": "q", "value": "arroz" },
                { "key": "inStock", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "****** {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\"sku\":\"ARROZ-5KG\",\"name\":\"Arroz Branco 5kg\",\"description\":\"Arroz branco tipo 1, grão longo\",\"price\":25.90,\"stock\":100,\"unit\":\"pct\",\"isActive\":true}"
            }
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/conversations?page=1&pageSize=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": "{{baseUrl}}/api/orders?page=1&pageSize=20"
          }
        }
      ]
    },
    {
      "name": "WhatsApp",
      "item": [
        {
          "name": "List Instances",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": "{{baseUrl}}/api/whatsapp/instances"
          }
        },
        {
          "name": "Webhook (test)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-webhook-secret", "value": "change-this-webhook-secret" }
            ],
            "url": "{{baseUrl}}/api/whatsapp/webhook",
            "body": {
              "mode": "raw",
              "raw": "{\"event\":\"messages.upsert\",\"instance\":\"default\",\"sender\":\"5511999990000@s.whatsapp.net\",\"data\":{\"pushName\":\"Teste\",\"message\":{\"key\":{\"remoteJid\":\"5511888880000@s.whatsapp.net\",\"fromMe\":false,\"id\":\"TEST001\"},\"messageTimestamp\":1720000000,\"message\":{\"conversation\":\"Olá! Tem arroz?\"}}}}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "****** {{accessToken}}" }],
            "url": "{{baseUrl}}/api/dashboard/metrics"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
